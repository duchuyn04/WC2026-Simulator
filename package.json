{
  "name": "wc2026-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run build:spa-fallback",
    "build:spa-fallback": "node -e \"const fs=require('fs');const out='out';if(fs.existsSync(out+'/index.html')){fs.copyFileSync(out+'/index.html',out+'/404.html');console.log('SPA fallback: index.html → 404.html')}\"",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:tester": "playwright test e2e/tester --reporter=list",
    "test:tester:report": "playwright test e2e/tester && playwright show-report",
    "test:all": "vitest run && playwright test",
    "survey:fifa": "node scripts/survey-fifa.mjs",
    "fetch:tournament-stats": "node scripts/fetch-fifa-tournament-stats.mjs",
    "fetch:rankings": "node scripts/fetch-fifa-rankings.mjs",
    "generate:annex-c": "node scripts/generate-annex-c.mjs",
    "survey:playwright": "node scripts/survey-fifa-playwright.mjs",
    "fetch:teams-squads": "node scripts/fetch-fifa-teams-squads.mjs",
    "test:e2e:ui": "playwright test --ui",
    "mcp:playwright": "npx @playwright/mcp@latest --port 8931",
    "download:flags": "node scripts/download-flags.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
